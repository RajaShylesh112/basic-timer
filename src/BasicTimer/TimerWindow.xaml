<Window x:Class="BasicTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BasicTimer"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        WindowStyle="None" 
        ResizeMode="NoResize"
        Title="Basic Timer" 
        Height="{Binding WindowHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=90}" 
        Width="260"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Topmost="True"
        Background="Transparent"
        >

    <Border CornerRadius="16" BorderThickness="1" BorderBrush="#E5E5E5" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#30000000" Direction="270" ShadowDepth="8" Opacity="0.25" BlurRadius="20"/>
        </Border.Effect>
        
        <Canvas
            Name="MainCanvas"
            Background="Transparent" 
            SizeChanged="MainCanvas_SizeChanged">

        <Rectangle 
            Name="ProgressBar"
            Fill="#0078D4"
            Width="{Binding ProgressWidth, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
            Height="{Binding ActualHeight, ElementName=MainCanvas}"
            RadiusX="15" RadiusY="15"
            Opacity="0.08">
        </Rectangle>
        
        <Label
            Content="{Binding Title, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='Timer'}"
            Foreground="#666666"
            VerticalContentAlignment="Top"
            HorizontalContentAlignment="Center"
            Width="{Binding ActualWidth, ElementName=MainCanvas}"
            Height="{Binding ActualHeight, ElementName=MainCanvas}"
            Margin="0,10,0,0"
            FontSize="11"
            FontWeight="Normal"
            />
        <Label 
            Content="{Binding Text, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, FallbackValue='00:00'}"
            Foreground="#323130"
            FontFamily="Segoe UI"
            FontWeight="SemiBold"
            FontSize="{Binding FontSize, NotifyOnSourceUpdated=True, FallbackValue=32}"
            Width="{Binding ActualWidth, ElementName=MainCanvas}"
            Height="{Binding ActualHeight, ElementName=MainCanvas}"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Margin="0"
            Name="TimerLabel">
        </Label>
        
        <TextBox 
            Text="{Binding EditableText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Foreground="#323130"
            Background="Transparent"
            FontFamily="Segoe UI"
            FontWeight="SemiBold"
            FontSize="{Binding FontSize, NotifyOnSourceUpdated=True, FallbackValue=32}"
            Width="{Binding ActualWidth, ElementName=MainCanvas}"
            Height="{Binding ActualHeight, ElementName=MainCanvas}"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderThickness="0"
            Margin="0"
            Name="EditTextBox"
            Visibility="Collapsed"
            KeyDown="EditTextBox_KeyDown"
            LostFocus="EditTextBox_LostFocus"
            SelectionBrush="#0078D4"
            CaretBrush="#0078D4">
        </TextBox>

        <Label 
            Name="TimerLabelWithContextMenu"
            Content=""
            Width="{Binding ActualWidth, ElementName=MainCanvas}"
            Height="{Binding ActualHeight, ElementName=MainCanvas}"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Background="Transparent"
            Margin="0"
            MouseDoubleClick="Label_MouseDoubleClick">

            <Label.ContextMenu>
                <ContextMenu Name="cm">

                    <MenuItem Header="Start (spacebar)" Click="MenuItem_Start_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="▶️" Foreground="Green" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Stop (spacebar)" Click="MenuItem_Stop_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⏹️" Foreground="Red" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Reset (r)" Click="MenuItem_Reset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⏮️" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Restart (s)" Click="MenuItem_Restart_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔁" Foreground="Green" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Set Time" Click="MenuItem_SetTime_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⌚" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Quick Presets" Click="MenuItem_QuickPresets_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⚡" Foreground="Orange" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Count Down" IsCheckable="True" IsChecked="{Binding CountDown}">
                        <MenuItem.Icon>
                            <TextBlock Text="⬇️" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Show Hours" IsCheckable="True" IsChecked="{Binding ShowHours}">
                        <MenuItem.Icon>
                            <TextBlock Text="🕐" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    
                    <Separator />
                    
                    <MenuItem Header="Copy Time" Click="MenuItem_Copy_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" Foreground="Blue" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Session History" Click="MenuItem_SessionHistory_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📊" Foreground="Purple" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator />

                    <MenuItem Header="Font Size">
                        <MenuItem.Icon>
                            <TextBlock Text="🔤" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                        <MenuItem Header="Small (18)" Click="MenuItem_FontSize_Click" Tag="18"/>
                        <MenuItem Header="Medium (24)" Click="MenuItem_FontSize_Click" Tag="24"/>
                        <MenuItem Header="Large (32)" Click="MenuItem_FontSize_Click" Tag="32"/>
                        <MenuItem Header="Extra Large (48)" Click="MenuItem_FontSize_Click" Tag="48"/>
                    </MenuItem>
                    
                    <MenuItem Header="Progress Bar">
                        <MenuItem.Icon>
                            <TextBlock Text="⏱️" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                        <MenuItem Header="1 sec" Click="MenuItem_ProgressUnitSize_Click" Tag="1"/>
                        <MenuItem Header="10 sec" Click="MenuItem_ProgressUnitSize_Click" Tag="10"/>
                        <MenuItem Header="30 sec" Click="MenuItem_ProgressUnitSize_Click" Tag="30"/>
                        <MenuItem Header="1 min" Click="MenuItem_ProgressUnitSize_Click" Tag="60"/>
                        <MenuItem Header="5 min" Click="MenuItem_ProgressUnitSize_Click" Tag="300"/>
                        <MenuItem Header="10 min" Click="MenuItem_ProgressUnitSize_Click" Tag="600"/>
                        <MenuItem Header="Disable" Click="MenuItem_ProgressUnitSize_Click" Tag="0"/>
                    </MenuItem>

                    <MenuItem Header="Toggle Title Bar" Click="MenuItem_ToggleTitleBar_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📱" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Always On Top" IsCheckable="True" IsChecked="True" Click="MenuItem_ToggleAlwaysOnTop_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📌" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Set Title" Click="MenuItem_ShowTitle_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📝" Foreground="Gray" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator />

                    <MenuItem Header="Exit" Click="MenuItem_ExitApp_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="❌" Foreground="Red" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Label.ContextMenu>
        </Label>
        </Canvas>
    </Border>
</Window>
